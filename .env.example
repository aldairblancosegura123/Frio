# MongoDB
MONGO_URI=
MONGO_DB_NAME=friotech

# JWT
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Firebase
# Opcion local (archivo):
FCM_CREDENTIALS_PATH=firebase-credentials.json
# Opcion Render (recomendada): pega el JSON completo en una sola linea
FCM_CREDENTIALS_JSON=

# App
ENV=development
DIAS_PROXIMO_MANTENIMIENTO=100

# CORS
# Ejemplos:
# CORS_ORIGINS=*
# CORS_ORIGINS=http://localhost:5173,https://tu-frontend.onrender.com
CORS_ORIGINS=*
